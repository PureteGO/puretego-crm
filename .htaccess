# Neutralized .htaccess to allow debugging
# The original configuration was causing a 500 error even for static files.

# Security only
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

<Files "*.pyc">
    Order allow,deny
    Deny from all
</Files>

# Do not add RewriteRules yet until we verify the server can serve test_server.txt
