# PURETEGO CRM - Minimal htaccess to restore access
# Se este arquivo der erro 500 para o .txt, o problema é no Apache do servidor.

RewriteEngine On
RewriteBase /

# Se o arquivo existir, serve ele direto (ex: test_server.txt)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule . - [L]

# Caso contrário, manda para o app (ajustado conforme o Setup Python App)
# Note: o cPanel geralmente insere os blocos PASSENGER automaticamente.
# Se você desativou o app, este arquivo deve servir apenas o estático.
