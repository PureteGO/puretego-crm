# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home2/puretego/maps2go_crm"
PassengerBaseURI "/"
PassengerPython "/home2/puretego/virtualenv/maps2go_crm/3.11/bin/python"
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

RewriteEngine On
RewriteBase /
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ passenger_wsgi.py/$1 [L]

# Configurações de segurança
<Files ".env">
    Order allow,deny
    Deny from all
</Files>
