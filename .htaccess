# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home2/appmaps2go/maps2go_crm"
PassengerBaseURI "/"
PassengerPython "/home2/appmaps2go/virtualenv/maps2go_crm/3.11/bin/python"
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

RewriteEngine On
RewriteBase /
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ run.py/$1 [L]

# Segurança
<Files ".env">
    Order allow,deny
    Deny from all
</Files>
