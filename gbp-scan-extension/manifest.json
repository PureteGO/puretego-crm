{
    "manifest_version": 3,
    "name": "Maps2GO - GBP Scan",
    "version": "1.0.0",
    "description": "Scan Google Business Profiles directly from Search/Maps — zero API cost",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.google.com/*",
                "https://www.google.com.py/*",
                "https://www.google.com.br/*",
                "https://www.google.es/*",
                "https://www.google.co.uk/*",
                "https://www.google.com.ar/*",
                "https://www.google.com.mx/*",
                "https://maps.google.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content_styles.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "host_permissions": [
        "https://*/*"
    ]
}